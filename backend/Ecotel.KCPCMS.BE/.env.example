# Reference values for local backend overrides.
# ASP.NET Core in this repo does not auto-load .env files.
# Use these keys in your terminal, launch profile, container env, or secret manager.

ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=https://localhost:8175;http://localhost:8182
DatabaseSettings__ConnectionString=Host=localhost;Port=15432;Database=<db_name>;Username=<db_user>;Password=<db_password>
AppSettings__ServerRootAddress=https://localhost:8175/
AppSettings__ClientRootAddress=http://localhost:5173/
SwaggerSettings__BaseUrl=https://localhost:8175
CorsSettings__AllowedOrigins=http://localhost:5173;https://localhost:5173;http://localhost:8175;https://localhost:8175
